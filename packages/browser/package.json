{
  "name": "@ai-fable/browser",
  "version": "0.0.0",
  "private": true,
  "description": "Browser Agent — state machine, high-level actions, and automation runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
