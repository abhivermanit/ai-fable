    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-fable/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
